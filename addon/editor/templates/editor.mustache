{{!
    @template tool_guidance/editor

    Shell for the guidance graph editor: a toolbar and a pannable surface that
    holds an SVG edge layer behind absolutely-positioned HTML node cards.

    Example context (json):
    {
    }
}}
<p class="text-muted mb-2">{{#str}}editorhint, tool_guidance{{/str}}</p>
<div class="tool-guidance-editor" data-region="editor" tabindex="0">
    <div class="tool-guidance-toolbar d-flex flex-wrap align-items-center" role="toolbar">
        <button type="button" class="btn btn-sm btn-secondary me-1" data-action="add-question">
            {{#str}}addquestion, tool_guidance{{/str}}
        </button>
        <button type="button" class="btn btn-sm btn-secondary me-1" data-action="add-leaf">
            {{#str}}addleaf, tool_guidance{{/str}}
        </button>
        <button type="button" class="btn btn-sm btn-secondary me-2" data-action="auto-layout"
            title="{{#str}}autolayouttitle, tool_guidance{{/str}}">
            {{#str}}autolayout, tool_guidance{{/str}}
        </button>
        <div class="btn-group btn-group-sm me-2" role="group" aria-label="{{#str}}zoomcontrols, tool_guidance{{/str}}">
            <button type="button" class="btn btn-outline-secondary" data-action="zoom-out"
                title="{{#str}}zoomout, tool_guidance{{/str}}" aria-label="{{#str}}zoomout, tool_guidance{{/str}}">&minus;</button>
            <button type="button" class="btn btn-outline-secondary" data-action="zoom-reset"
                title="{{#str}}zoomreset, tool_guidance{{/str}}">100%</button>
            <button type="button" class="btn btn-outline-secondary" data-action="zoom-in"
                title="{{#str}}zoomin, tool_guidance{{/str}}" aria-label="{{#str}}zoomin, tool_guidance{{/str}}">+</button>
            <button type="button" class="btn btn-outline-secondary" data-action="zoom-fit"
                title="{{#str}}zoomfit, tool_guidance{{/str}}">{{#str}}zoomfit, tool_guidance{{/str}}</button>
        </div>
    </div>
    <div class="tool-guidance-surface" data-region="surface">
        <svg class="tool-guidance-edges" data-region="edges" xmlns="http://www.w3.org/2000/svg"></svg>
        <div class="tool-guidance-nodes" data-region="nodes"></div>
    </div>
</div>
