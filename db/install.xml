<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/guidance/db" VERSION="20260701" COMMENT="XMLDB file for tool_guidance"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="tool_guidance_graph" COMMENT="A guidance graph: an admin-authored decision tree that may contain several root nodes.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Human readable graph name."/>
        <FIELD NAME="idnumber" TYPE="char" LENGTH="100" NOTNULL="false" SEQUENCE="false" COMMENT="Optional machine key for the graph."/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Longer description shown to admins."/>
        <FIELD NAME="descriptionformat" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether the graph is active."/>
        <FIELD NAME="usermodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="usermodified" TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idnumber" UNIQUE="false" FIELDS="idnumber"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="tool_guidance_node" COMMENT="A node in a guidance graph: either a question or a leaf.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="graphid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Owning graph."/>
        <FIELD NAME="type" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" COMMENT="question or leaf."/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Question text or leaf heading."/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Longer body text."/>
        <FIELD NAME="descriptionformat" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="isroot" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether this node is a root (entry point) of its tree; a graph may have several."/>
        <FIELD NAME="targettype" TYPE="char" LENGTH="40" NOTNULL="false" SEQUENCE="false" COMMENT="Leaf only: activity, route or url."/>
        <FIELD NAME="targetconfig" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Leaf only: JSON config for the target type."/>
        <FIELD NAME="posx" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Canvas X position."/>
        <FIELD NAME="posy" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Canvas Y position."/>
        <FIELD NAME="usermodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="graphid" TYPE="foreign" FIELDS="graphid" REFTABLE="tool_guidance_graph" REFFIELDS="id"/>
        <KEY NAME="usermodified" TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="graphid-isroot" UNIQUE="false" FIELDS="graphid, isroot"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="tool_guidance_link" COMMENT="A directed edge between two nodes, carrying the answer label.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="graphid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Owning graph; both endpoints share it."/>
        <FIELD NAME="parentnodeid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Source question node."/>
        <FIELD NAME="childnodeid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Target node; null while the answer is dangling."/>
        <FIELD NAME="answerlabel" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" COMMENT="Answer shown on the edge."/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="posx" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Answer box canvas X position."/>
        <FIELD NAME="posy" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Answer box canvas Y position."/>
        <FIELD NAME="usermodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="graphid" TYPE="foreign" FIELDS="graphid" REFTABLE="tool_guidance_graph" REFFIELDS="id"/>
        <KEY NAME="parentnodeid" TYPE="foreign" FIELDS="parentnodeid" REFTABLE="tool_guidance_node" REFFIELDS="id"/>
        <KEY NAME="childnodeid" TYPE="foreign" FIELDS="childnodeid" REFTABLE="tool_guidance_node" REFFIELDS="id"/>
        <KEY NAME="usermodified" TYPE="foreign" FIELDS="usermodified" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="parent-sort" UNIQUE="false" FIELDS="parentnodeid, sortorder"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="tool_guidance_rule" COMMENT="Deterministic condition-to-suggestion rules, evaluated in sortorder precedence.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Precedence; lower wins."/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="signaltype" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" COMMENT="gap|lifecycle|engagement"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="conditiontext" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="Condition DSL expression."/>
        <FIELD NAME="suggestmod" TYPE="char" LENGTH="32" NOTNULL="true" SEQUENCE="false" COMMENT="Suggested activity module name."/>
        <FIELD NAME="rationale" TYPE="text" NOTNULL="true" SEQUENCE="false" COMMENT="Teacher-facing reason."/>
        <FIELD NAME="preconfig" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Opaque preconfig payload for the add-activity flow."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="sortorder" UNIQUE="false" FIELDS="sortorder"/>
        <INDEX NAME="enabled" UNIQUE="false" FIELDS="enabled"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="tool_guidance_dismissed" COMMENT="Course-wide dismissals of a suggestion rule with a timestamp for cooldown.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="ruleid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="User who dismissed it."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="ruleid" TYPE="foreign" FIELDS="ruleid" REFTABLE="tool_guidance_rule" REFFIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid-ruleid" UNIQUE="true" FIELDS="courseid, ruleid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
