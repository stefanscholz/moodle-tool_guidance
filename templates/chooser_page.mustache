{{!
    @template tool_guidance/chooser_page

    Shell for the guidance decision-tree chooser.

    Context variables required for this template:
    * title - Page title.
    * intro - Short introduction sentence.
    * isstart - Whether the active node is the first node.
    * starturl - URL of the first node (for "Start over").
    * startoverlabel - Label for the "Start over" link.
    * node - The active node context (see tool_guidance/chooser_question and chooser_result).

    Example context (json):
    {
        "title": "What do you want students to do next?",
        "intro": "Answer a few questions and we will suggest an activity.",
        "isstart": true,
        "starturl": "https://example.com/chooser.php?courseid=2",
        "startoverlabel": "Start over",
        "node": {
            "isquestion": true,
            "isresult": false,
            "prompt": "What is your main goal?",
            "answers": [
                {"label": "Check understanding", "url": "https://example.com/?node=q_assess", "target": "q_assess"}
            ],
            "presets": []
        }
    }
}}
<div class="tool-guidance-chooser" data-region="tool-guidance-chooser">
    <h2 class="tool-guidance-title">{{title}}</h2>
    <p class="tool-guidance-intro text-muted">{{intro}}</p>

    <div class="tool-guidance-node" data-region="tool-guidance-node" tabindex="-1">
        {{^isstart}}
            <p class="tool-guidance-controls">
                <a href="{{starturl}}" class="tool-guidance-startover" data-action="startover">
                    {{startoverlabel}}
                </a>
            </p>
        {{/isstart}}

        {{#node}}
            {{#isquestion}}{{> tool_guidance/chooser_question}}{{/isquestion}}
            {{#isresult}}{{> tool_guidance/chooser_result}}{{/isresult}}
        {{/node}}
    </div>
</div>
