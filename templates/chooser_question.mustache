{{!
    @template tool_guidance/chooser_question

    A decision-tree question node.

    Context variables required for this template:
    * prompt - The question text.
    * answers - List of {label, url, target} answers.

    Example context (json):
    {
        "prompt": "What is your main goal?",
        "answers": [
            {"label": "Check understanding", "url": "https://example.com/?node=q_assess", "target": "q_assess"}
        ]
    }
}}
<div class="tool-guidance-question">
    <h3 class="tool-guidance-prompt">{{prompt}}</h3>
    <ul class="tool-guidance-answers list-unstyled">
        {{#answers}}
            <li class="tool-guidance-answer-item">
                <a class="btn btn-outline-primary tool-guidance-answer" href="{{url}}" data-target="{{target}}">
                    {{label}}
                </a>
            </li>
        {{/answers}}
    </ul>
</div>
