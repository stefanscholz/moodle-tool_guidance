{{!
    @template tool_guidance/chooser_question

    A decision-tree question node.

    Context variables required for this template:
    * prompt - The question text.
    * answers - List of {label, explanation, url, target} answers.

    Example context (json):
    {
        "prompt": "What is your main goal?",
        "answers": [
            {
                "label": "Check understanding",
                "explanation": "See what students already know before you teach.",
                "url": "https://example.com/?node=q_assess",
                "target": "q_assess"
            }
        ]
    }
}}
<div class="tool-guidance-question">
    <h3 class="tool-guidance-prompt">{{prompt}}</h3>
    <ul class="tool-guidance-answers list-unstyled">
        {{#answers}}
            <li class="tool-guidance-answer-item">
                <a class="card h-100 tool-guidance-answer" href="{{url}}" data-target="{{target}}">
                    <div class="card-body">
                        <h4 class="card-title h6 mb-1">{{label}}</h4>
                        <p class="card-text text-muted small mb-0">{{explanation}}</p>
                    </div>
                </a>
            </li>
        {{/answers}}
    </ul>
</div>
