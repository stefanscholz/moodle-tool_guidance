{{!
    @template tool_guidance/chooser_result

    A decision-tree result node, listing suggested activity presets.

    Context variables required for this template:
    * prompt - The result heading.
    * presets - List of {modname, iconurl, title, description, useurl, canapply, presetid,
      courseid, section, sesskey, config:[{name, value}]}.

    Example context (json):
    {
        "prompt": "A quiz is a good fit",
        "presets": [
            {
                "modname": "quiz",
                "iconurl": "https://example.com/quiz.svg",
                "title": "Diagnostic quiz",
                "description": "A short, auto-graded quiz.",
                "useurl": "https://example.com/course/view.php?id=2",
                "canapply": true,
                "presetid": 3,
                "courseid": 2,
                "section": 1,
                "sesskey": "abc123",
                "config": [{"name": "Number of questions", "value": "5"}]
            }
        ]
    }
}}
<div class="tool-guidance-result">
    <h3 class="tool-guidance-prompt">{{prompt}}</h3>
    {{#description}}
        <div class="tool-guidance-node-description text-muted mb-3">{{{description}}}</div>
    {{/description}}
    <p class="tool-guidance-presets-label text-muted">{{#str}}suggestedpresets, tool_guidance{{/str}}</p>
    <div class="tool-guidance-presets">
        {{#presets}}
            <div class="card tool-guidance-preset">
                <div class="card-body">
                    <div class="tool-guidance-preset-head">
                        <img src="{{iconurl}}" alt="" aria-hidden="true" class="tool-guidance-preset-icon">
                        <h4 class="tool-guidance-preset-title">{{title}}</h4>
                    </div>
                    <div class="tool-guidance-preset-desc">{{{description}}}</div>
                    {{#config.0}}
                        <details class="tool-guidance-preset-configdetails">
                            <summary>{{#str}}showconfig, tool_guidance{{/str}}</summary>
                            <dl class="tool-guidance-preset-config">
                                {{#config}}
                                    <div class="tool-guidance-config-row">
                                        <dt>{{name}}</dt>
                                        <dd>{{value}}</dd>
                                    </div>
                                {{/config}}
                            </dl>
                        </details>
                    {{/config.0}}
                    {{#canapply}}
                        <form action="{{config.wwwroot}}/admin/tool/guidance/addon/preset/apply.php" method="post"
                            class="tool-guidance-usepreset-form">
                            <input type="hidden" name="sesskey" value="{{sesskey}}">
                            <input type="hidden" name="presetid" value="{{presetid}}">
                            <input type="hidden" name="courseid" value="{{courseid}}">
                            <input type="hidden" name="section" value="{{section}}">
                            <button type="submit" class="btn btn-primary tool-guidance-usepreset" data-action="usepreset">
                                {{#str}}usepreset, tool_guidance{{/str}}
                            </button>
                        </form>
                    {{/canapply}}
                    {{^canapply}}
                        <a href="{{useurl}}" class="btn btn-primary tool-guidance-usepreset" data-action="usepreset">
                            {{#str}}usepreset, tool_guidance{{/str}}
                        </a>
                        <p class="tool-guidance-preset-note text-muted">
                            {{#str}}usepresetnote, tool_guidance{{/str}}
                        </p>
                    {{/canapply}}
                </div>
            </div>
        {{/presets}}
    </div>
</div>
